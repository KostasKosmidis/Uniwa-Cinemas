const movieService = require("../services/movieService");

exports.getAll = async (req, res) => {
  res.json(await movieService.getAll());
};

exports.getOne = async (req, res) => {
  res.json(await movieService.getOne(req.params.id));
};

exports.create = async (req, res) => {
  res.json(await movieService.create(req.body));
};

exports.update = async (req, res) => {
  res.json(await movieService.update(req.params.id, req.body));
};

exports.delete = async (req, res) => {
  res.json(await movieService.delete(req.params.id));
};